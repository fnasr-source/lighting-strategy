rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profiles ──
    // Authenticated users can read their own profile
    // Owners/admins can read all profiles (for team management)
    match /userProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin']
      );
    }

    // ── Clients ──
    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Invoices ──
    match /invoices/{invoiceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Payments ──
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Leads ──
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin', 'team'];
    }

    // ── Proposals ──
    match /proposals/{proposalId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Platform Connections (credentials — restricted) ──
    match /platformConnections/{connId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Monthly Metrics + Rollups (reporting) ──
    match /monthlyPlatformMetrics/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }
    match /monthlyClientRollups/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Threads + Messages (communication) ──
    match /threads/{threadId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Recurring Invoices + Reminders ──
    match /recurringInvoices/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }
    match /invoiceReminders/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // ── Expenses ──
    match /expenses/{expenseId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }
  }
}
