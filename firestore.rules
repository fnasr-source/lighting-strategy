rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function profileDoc() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function role() {
      return profileDoc().role;
    }

    function isOwnerOrAdmin() {
      return isSignedIn() && role() in ['owner', 'admin'];
    }

    function isInternal() {
      return isSignedIn() && role() in ['owner', 'admin', 'team'];
    }

    function canAccessClient(clientId) {
      return clientId is string && (
        isOwnerOrAdmin()
        || (isSignedIn() && role() == 'team' && profileDoc().assignedClients is list && profileDoc().assignedClients.hasAny([clientId]))
        || (isSignedIn() && role() == 'client' && (
          (profileDoc().linkedClientIds is list && profileDoc().linkedClientIds.hasAny([clientId]))
          || profileDoc().linkedClientId == clientId
        ))
      );
    }

    function threadClientId(threadId) {
      return get(/databases/$(database)/documents/threads/$(threadId)).data.clientId;
    }

    function artifactReadable(data) {
      return isInternal() || (
        isSignedIn()
        && data.visibility == 'client'
        && canAccessClient(data.clientId)
      );
    }

    function artifactWritable(data) {
      return isInternal() && canAccessClient(data.clientId);
    }

    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid || isOwnerOrAdmin() || role() == 'team'
      );
      allow write: if isSignedIn() && (
        request.auth.uid == uid || isOwnerOrAdmin()
      );
    }

    match /clients/{clientId} {
      allow read: if canAccessClient(clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /leads/{leadId} {
      allow read: if isInternal();
      allow write: if isInternal();
    }

    match /proposals/{proposalId} {
      allow read: if isInternal() || (isSignedIn() && canAccessClient(resource.data.clientId));
      allow write: if isOwnerOrAdmin();
    }

    match /platformConnections/{connId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /systemConfig/{docId} {
      allow read: if isOwnerOrAdmin();
      allow write: if isOwnerOrAdmin();
    }
    match /platformDataOverrides/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /fxRates/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwnerOrAdmin();
    }

    match /monthlyPlatformMetrics/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /monthlyClientRollups/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /dailyPlatformMetrics/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /fact_marketing_daily/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_marketing_hourly/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_social_interaction/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_social_conversation/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /kpi_snapshots_daily/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /kpi_snapshots_hourly/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /client_health_scores/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /aiRecommendations/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /ingestionJobs/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /intelligenceCronRuns/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    match /creativePerformance/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    match /threads/{threadId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow create: if isSignedIn() && canAccessClient(request.resource.data.clientId);
      allow update, delete: if isSignedIn() && canAccessClient(resource.data.clientId);
    }
    match /messages/{messageId} {
      allow read: if isSignedIn() && canAccessClient(threadClientId(resource.data.threadId));
      allow create: if isSignedIn() && canAccessClient(threadClientId(request.resource.data.threadId));
      allow update, delete: if isInternal() && canAccessClient(threadClientId(resource.data.threadId));
    }

    match /recurringInvoices/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /invoiceReminders/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    match /recurringExpenses/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /cashAccounts/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeInboxItems/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeEntries/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeAlerts/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    match /reports/{reportId} {
      allow read: if isInternal() || (isSignedIn() && canAccessClient(resource.data.clientId));
      allow write: if isInternal();
    }
    match /strategies/{strategyId} {
      allow read: if isInternal() || (isSignedIn() && canAccessClient(resource.data.clientId));
      allow write: if isInternal();
    }
    match /clientArtifacts/{artifactId} {
      allow read: if artifactReadable(resource.data);
      allow create: if artifactWritable(request.resource.data);
      allow update, delete: if artifactWritable(resource.data);
    }
    match /clientArtifactVersions/{versionId} {
      allow read: if artifactReadable(resource.data);
      allow create: if artifactWritable(request.resource.data);
      allow update, delete: if artifactWritable(resource.data);
    }
    match /clientApprovals/{approvalId} {
      allow read: if isInternal() || (isSignedIn() && canAccessClient(resource.data.clientId));
      allow create: if isSignedIn() && canAccessClient(request.resource.data.clientId);
      allow update, delete: if isSignedIn() && canAccessClient(resource.data.clientId);
    }

    match /campaigns/{campaignId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();

      match /leads/{leadId} {
        allow create: if true;
        allow read: if isInternal();
        allow update, delete: if isInternal();

        match /activities/{activityId} {
          allow create, read: if isInternal();
          allow update, delete: if isOwnerOrAdmin();
        }
      }
    }

    match /clientInsights/{clientId} {
      allow read: if canAccessClient(clientId);
      allow write: if isOwnerOrAdmin();
    }
  }
}
