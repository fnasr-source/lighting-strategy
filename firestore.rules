rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function profileDoc() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function role() {
      return profileDoc().role;
    }

    function isOwnerOrAdmin() {
      return isSignedIn() && role() in ['owner', 'admin'];
    }

    function isInternal() {
      return isSignedIn() && role() in ['owner', 'admin', 'team'];
    }

    function canAccessClient(clientId) {
      return isOwnerOrAdmin()
        || (isSignedIn() && role() == 'team' && profileDoc().assignedClients is list && profileDoc().assignedClients.hasAny([clientId]))
        || (isSignedIn() && role() == 'client' && profileDoc().linkedClientId == clientId);
    }

    // ── User Profiles ──
    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid || isOwnerOrAdmin() || role() == 'team'
      );
      allow write: if isSignedIn() && (
        request.auth.uid == uid || isOwnerOrAdmin()
      );
    }

    // ── Clients ──
    match /clients/{clientId} {
      allow read: if canAccessClient(clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Invoices ──
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        isOwnerOrAdmin()
        || (role() == 'team' && profileDoc().assignedClients is list && profileDoc().assignedClients.hasAny([resource.data.clientId]))
        || (role() == 'client' && profileDoc().linkedClientId == resource.data.clientId)
      );
      allow write: if isOwnerOrAdmin();
    }

    // ── Payments ──
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        isOwnerOrAdmin()
        || (role() == 'team' && profileDoc().assignedClients is list && profileDoc().assignedClients.hasAny([resource.data.clientId]))
        || (role() == 'client' && profileDoc().linkedClientId == resource.data.clientId)
      );
      allow write: if isOwnerOrAdmin();
    }

    // ── Leads ──
    match /leads/{leadId} {
      allow read: if isInternal();
      allow write: if isInternal();
    }

    // ── Proposals ──
    match /proposals/{proposalId} {
      allow read: if isInternal() || (isSignedIn() && role() == 'client' && profileDoc().linkedClientId == resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Platform Connections (credentials metadata only) ──
    match /platformConnections/{connId} {
      allow read: if isInternal() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Secret storage and platform overrides ──
    match /systemConfig/{docId} {
      allow read: if isOwnerOrAdmin();
      allow write: if isOwnerOrAdmin();
    }
    match /platformDataOverrides/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /fxRates/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwnerOrAdmin();
    }

    // ── Monthly + Daily Metrics (legacy reporting collections) ──
    match /monthlyPlatformMetrics/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /monthlyClientRollups/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /dailyPlatformMetrics/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Canonical Intelligence Fact Tables ──
    match /fact_marketing_daily/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_marketing_hourly/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_social_interaction/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /fact_social_conversation/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Intelligence Outputs ──
    match /kpi_snapshots_daily/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /kpi_snapshots_hourly/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /client_health_scores/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /aiRecommendations/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /ingestionJobs/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }
    match /intelligenceCronRuns/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    // ── Media/creative intelligence ──
    match /creativePerformance/{docId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isOwnerOrAdmin();
    }

    // ── Threads + Messages (communication) ──
    match /threads/{threadId} {
      allow read: if isSignedIn() && canAccessClient(resource.data.clientId);
      allow write: if isSignedIn() && canAccessClient(request.resource.data.clientId);
    }
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Recurring Invoices + Reminders ──
    match /recurringInvoices/{docId} {
      allow read: if isSignedIn() && (
        isOwnerOrAdmin()
        || (role() == 'team' && profileDoc().assignedClients is list && profileDoc().assignedClients.hasAny([resource.data.clientId]))
        || (role() == 'client' && profileDoc().linkedClientId == resource.data.clientId)
      );
      allow write: if isOwnerOrAdmin();
    }
    match /invoiceReminders/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    // ── Expenses ──
    match /expenses/{expenseId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    // ── Finance Ops ──
    match /recurringExpenses/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /cashAccounts/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeInboxItems/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeEntries/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }
    match /financeAlerts/{docId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();
    }

    // ── Reports / Strategy ──
    match /reports/{reportId} {
      allow read: if isInternal() || (isSignedIn() && role() == 'client' && profileDoc().linkedClientId == resource.data.clientId);
      allow write: if isInternal();
    }
    match /strategies/{strategyId} {
      allow read: if isInternal() || (isSignedIn() && role() == 'client' && profileDoc().linkedClientId == resource.data.clientId);
      allow write: if isInternal();
    }

    // ── Campaigns (public lead intake + internal management) ──
    match /campaigns/{campaignId} {
      allow read: if isInternal();
      allow write: if isOwnerOrAdmin();

      match /leads/{leadId} {
        allow create: if true;
        allow read: if isInternal();
        allow update, delete: if isInternal();

        match /activities/{activityId} {
          allow create, read: if isInternal();
          allow update, delete: if isOwnerOrAdmin();
        }
      }
    }

    // ── AI-generated summary cache (legacy) ──
    match /clientInsights/{clientId} {
      allow read: if canAccessClient(clientId);
      allow write: if isOwnerOrAdmin();
    }
  }
}
